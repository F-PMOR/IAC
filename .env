# Proxmox Credentials
PROXMOX_HOST=
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=
PROXMOX_NODE=
PROXMOX_VERIFY_SSL=false

# Terraform Proxmox Provider
TF_VAR_proxmox_api_url=https://${PROXMOX_HOST}:8006/api2/json
TF_VAR_proxmox_api_token_id=${PROXMOX_TOKEN_ID}
TF_VAR_proxmox_api_token_secret=${PROXMOX_TOKEN_SECRET}
TF_VAR_proxmox_node=${PROXMOX_NODE}

# Python
PYTHONUNBUFFERED=1

# Variables personnalisées (ajoutez les vôtres)
# ANSIBLE_USER=admin
# ANSIBLE_BECOME_METHOD=sudo
